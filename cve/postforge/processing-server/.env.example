# PostForge Processing Server Configuration

# Server
NODE_ENV=development
PORT=4000
DEBUG=false

# Authentication
PROCESSING_API_KEY=pf-process-key-change-in-production
REQUIRE_AUTH=true

# File Storage
UPLOAD_DIR=/tmp/postforge-uploads
CLIPS_DIR=/tmp/postforge-clips
MAX_VIDEO_SIZE=536870912  # 500MB in bytes

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Whisper Configuration
WHISPER_MODEL=base  # tiny, base, small, medium, large
WHISPER_LANGUAGE=en  # auto-detect if empty

# FFmpeg Configuration
FFMPEG_PRESET=medium  # fast, medium, slow (quality vs speed)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# Logging
LOG_LEVEL=info  # debug, info, warn, error
